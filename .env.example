APP_NAME=aegis
APP_ENV=development
APP_VERSION=dev
APP_STARTUP_TIMEOUT=20s
APP_SHUTDOWN_TIMEOUT=15s

LOG_LEVEL=info

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

WORKER_CONSUMER_TAG=aegis-worker
WORKER_TRANSFER_MAX_RETRIES=3
WORKER_TRANSFER_RETRY_DELAY=2s
WORKER_TRANSFER_PROCESS_LOCK_TTL=30s
WORKER_TRANSFER_OUTBOX_POLL_INTERVAL=2s
WORKER_TRANSFER_OUTBOX_BATCH_SIZE=25
WORKER_TRANSFER_OUTBOX_RETRY_DELAY=2s
WORKER_TRANSFER_OUTBOX_PROCESSING_AFTER=30s
WORKER_WEBHOOK_POLL_INTERVAL=2s

WEBHOOK_TIMEOUT=10s
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_INITIAL_BACKOFF=2s
WEBHOOK_BATCH_SIZE=25
WEBHOOK_LEASE_DURATION=30s

DATABASE_URL=postgres://aegis:aegis@127.0.0.1:5432/aegis?sslmode=disable
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2
DATABASE_MAX_CONN_LIFETIME=30m
DATABASE_MAX_CONN_IDLE_TIME=5m

REDIS_ADDR=127.0.0.1:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

RABBITMQ_URL=amqp://aegis:aegis@127.0.0.1:5672/
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_EXCHANGE=aegis.events
RABBITMQ_TRANSFER_QUEUE=transfer_requests
RABBITMQ_TRANSFER_ROUTING_KEY=transfers.requested

EVM_RPC_URL=
EVM_CHAIN_ID=1
EVM_REQUEST_TIMEOUT=10s
